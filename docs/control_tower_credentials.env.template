# Forex AI Control Tower Credentials Paste Form
#
# Copy this file to:
#   secrets/control_tower_credentials.env
#
# Fill the values locally. Do not commit, screenshot, paste into chat, or upload the filled file.
# The `secrets/` directory is ignored by Git.
#
# Use plain KEY=value lines. Avoid surrounding values with quotes unless the value itself requires them.

# ============================================================
# DEPLOYMENT ACCESS
# Required when the controller runs Ansible/GitHub automation.
# These values are used by the controller only and are not copied to app runtime secret files.
# ============================================================
GITHUB_OWNER=<github_owner>
GITHUB_REPO=forex-ai-control-tower
GITHUB_TOKEN=<github_token>

LINUX_STANDARD_SSH_PASSWORD=<linux_ssh_password>
LINUX_STANDARD_SUDO_PASSWORD=<linux_sudo_password>

WINDOWS_MT5_USER=<windows_username>
WINDOWS_MT5_PASSWORD=<windows_winrm_password>
WINDOWS_MT5_SSH_PASSWORD=<windows_ssh_password_if_used>

# ============================================================
# CORE REBOOT-PERSISTENT RUNTIME SECRETS
# Required for production services after reboot.
# ============================================================
POSTGRES_PASSWORD=<postgres_password>
GRAFANA_ADMIN_PASSWORD=<grafana_admin_password>
JWT_SECRET_KEY=<long_random_jwt_secret>
EXECUTION_GUARD_SIGNING_KEY=<long_random_execution_guard_key>
BRIDGE_API_TOKEN=<long_random_bridge_api_token>
TELEMETRY_INGEST_TOKEN=<long_random_telemetry_ingest_token>

# Optional temporary local admin bootstrap. Disable after admin login is created.
LOCAL_AUTH_BOOTSTRAP_ENABLED=false
LOCAL_ADMIN_BOOTSTRAP_PASSWORD=
TOTP_ISSUER=Forex AI Control Tower
RECOVERY_EMAIL=m.asri.kamaruddin@gmail.com

# ============================================================
# TRADING SAFETY FLAGS
# Keep these conservative unless the formal approval records say otherwise.
# ============================================================
ALLOW_LIVE_TRADING=true
BRIDGE_MODE=demo
REQUIRE_ORDER_CHECK=true

# ============================================================
# NEWS / FUNDAMENTAL DATA
# FMP is currently wired as the live provider.
# ============================================================
NEWS_PROVIDER_ENABLED=true
NEWS_PROVIDER_TYPE=fmp_economic_calendar
NEWS_PROVIDER_API_KEY=<fmp_api_key>
NEWS_HIGH_IMPACT_WINDOW_MINUTES=45
NEWS_STALE_AFTER_MINUTES=720
NEWS_CALENDAR_FROM=
NEWS_CALENDAR_TO=
NEWS_CALENDAR_FILE=
NEWS_CALENDAR_URL=

# ============================================================
# NOTIFICATIONS / APPROVAL DELIVERY
# Configure Telegram first so approval messages can leave the dashboard.
# ============================================================
TELEGRAM_BOT_TOKEN=<telegram_bot_token>
TELEGRAM_ADMIN_CHAT_ID=<telegram_admin_chat_id>

WHATSAPP_TOKEN=<whatsapp_business_cloud_token>
WHATSAPP_PHONE_NUMBER_ID=<whatsapp_phone_number_id>

SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASSWORD=<smtp_password_or_app_password>
SMTP_FROM=<alerts_sender_email>

FCM_PROJECT_ID=<firebase_project_id>
FCM_SERVER_KEY=<firebase_legacy_server_key_if_used>
FCM_SERVICE_ACCOUNT_JSON=<firebase_service_account_json_or_secret_manager_reference>

VAPID_PUBLIC_KEY=<browser_push_vapid_public_key>
VAPID_PRIVATE_KEY=<browser_push_vapid_private_key>

DISCORD_WEBHOOK_URL=<optional_discord_webhook_url>
SMS_PROVIDER_TOKEN=<optional_sms_provider_token>
ALERTMANAGER_WEBHOOK_TOKEN=<optional_alertmanager_webhook_token>

# ============================================================
# PAID LLM ROUTING
# Leave paid routing disabled until budgets and approvals are ready.
# ============================================================
OPENAI_API_KEY=<openai_api_key>
GEMINI_API_KEY=<gemini_api_key>
LLM_DAILY_BUDGET_USD=0
LLM_MONTHLY_BUDGET_USD=0
PAID_LLM_APPROVAL_REQUIRED=true

# ============================================================
# OPENCLAW OPTIONAL HUMAN-FACING LAYER
# Must remain disabled until reviewed.
# ============================================================
OPENCLAW_ENABLED=false
OPENCLAW_API_URL=
OPENCLAW_API_TOKEN=<openclaw_api_token_if_enabled>

# ============================================================
# MT5 MULTI-ACCOUNT / BRIDGE SETTINGS
# Do not put broker passwords here unless you have chosen an approved encrypted secret path.
# Prefer manual MT5 login or a real secret manager for broker credentials.
# ============================================================
MT5_DEFAULT_ACCOUNT_ID=demo_main
MT5_DEFAULT_BRIDGE_PORT=8501
MT5_ACCOUNT_PROFILES_FILE=C:\ForexAI\mt5_bridge\account_profiles.json
